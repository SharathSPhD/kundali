# --- auth ---
# Supabase JWKS endpoint (ES256/RS256 verification, cached 1h)
SUPABASE_JWKS_URL=https://YOUR-PROJECT-REF.supabase.co/auth/v1/.well-known/jwks.json
# HS256 fallback (Supabase legacy JWT secret)
SUPABASE_JWT_SECRET=
# Set to 1 to disable auth entirely (local dev / tests only)
AUTH_DISABLED=0

# --- CORS ---
ALLOWED_ORIGINS=http://localhost:3000

# --- ephemeris ---
# Directory with Swiss Ephemeris .se1 files (optional; Moshier fallback is used otherwise)
SE_EPHE_PATH=

# --- LLM interpretation (optional) ---
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
